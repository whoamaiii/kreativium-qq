generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Kid {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  stars     Int        @default(0)
  starTotal Int        @default(0)
  Feedback  Feedback[]
  goals     Goal[]
}

model Goal {
  id          Int      @id @default(autoincrement())
  title       String
  desc        String?
  pct         Int
  pctComplete Int      @default(0)
  targetXp    Int      @default(100)
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  kidId       Int
  entries     Entry[]
  kid         Kid      @relation(fields: [kidId], references: [id], onDelete: Cascade)
}

model Entry {
  id        Int       @id @default(autoincrement())
  activity  String
  subject   String?
  status    String
  due       DateTime?
  notes     String?
  delta     Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  kidId     Int
  goalId    Int
  goal      Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

model Feedback {
  id        Int      @id @default(autoincrement())
  kidId     Int
  content   String
  role      String
  createdAt DateTime @default(now())
  Kid       Kid      @relation(fields: [kidId], references: [id])

  @@index([kidId, createdAt])
}
